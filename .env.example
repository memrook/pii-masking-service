# ============================================================
# .env.example — PII Masking Service
# cp .env.example .env
# ============================================================

# Redis
REDIS_PASSWORD=change_me_strong_password_here

# API Key (если пусто — авторизация отключена)
API_KEY=

# ОБЯЗАТЕЛЬНО: секрет для генерации суррогатов (HMAC-сид).
# Без него сервис НЕ стартует. Один секрет на ВСЕ воркеры — иначе один и тот же
# PII даст разные суррогаты в разных воркерах и round-trip сломается.
# Сгенерировать: openssl rand -hex 32
SURROGATE_SECRET=

# TTL маппинга в Redis (секунды)
MAPPING_TTL=300

# Порт сервиса (при standalone запуске)
PII_PORT=8000

# Число воркеров uvicorn
API_WORKERS=2

# Логирование
LOG_LEVEL=INFO

# Subpath при размещении за reverse-proxy (пусто = корень)
# API_ROOT_PATH=/ai/masking
