# ============================================================
# .env.example — PII Masking Service
# cp .env.example .env
# ============================================================

# Redis
REDIS_PASSWORD=change_me_strong_password_here

# API Key (если пусто — авторизация отключена)
API_KEY=

# TTL маппинга в Redis (секунды)
MAPPING_TTL=300

# Порт сервиса (при standalone запуске)
PII_PORT=8000

# Число воркеров uvicorn
API_WORKERS=2

# Логирование
LOG_LEVEL=INFO
